# Copy this to .env.local and fill in your values

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google Maps API Key (must have Maps JavaScript API enabled)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Custom SMS Gateway API Configuration (optional, falls back to mock endpoints)
VITE_SMS_API_URL=https://api.example.com/send-sms
VITE_SMS_API_KEY=your_sms_api_key
VITE_SMS_SENDER_ID=your_sender_id

